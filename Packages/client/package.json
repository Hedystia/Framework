{
  "name": "@hedystia/client",
  "version": "1.10.1",
  "description": "Next-gen TypeScript framework for building type-safe APIs at lightspeed",
  "devDependencies": {
    "@types/bun": "^1.3.3"
  },
  "dependencies": {
    "hedystia": "^1.10.1"
  },
  "peerDependencies": {
    "typescript": ">= 5.0.0",
    "hedystia": ">= 1.10.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "hedystia": {
      "optional": false
    }
  },
  "private": false,
  "keywords": [
    "hedystia",
    "framework",
    "typescript",
    "api",
    "type-safe",
    "bun",
    "server",
    "backend",
    "web"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "bun --watch --no-clear-screen run src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}
