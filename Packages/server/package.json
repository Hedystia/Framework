{
  "name": "hedystia",
  "version": "1.10.1",
  "description": "Next-gen TypeScript framework for building type-safe APIs at lightspeed",
  "dependencies": {
    "@hedystia/types": "^1.10.1",
    "@hedystia/validations": "^1.10.1"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@types/bun": "^1.3.3",
    "tsup": "^8.3.5"
  },
  "peerDependencies": {
    "@hedystia/types": ">= 1.10.0",
    "@hedystia/validations": ">= 1.10.0",
    "typescript": ">= 5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "@hedystia/validations": {
      "optional": false
    },
    "@hedystia/types": {
      "optional": false
    }
  },
  "private": false,
  "keywords": [
    "hedystia",
    "framework",
    "typescript",
    "api",
    "type-safe",
    "bun",
    "server",
    "backend",
    "web"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "bun --watch --no-clear-screen run src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js"
}
