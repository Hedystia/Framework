{
  "name": "framework",
  "license": "MIT",
  "homepage": "https://docs.hedystia.com",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.11",
    "bumpp": "^11.0.1",
    "changelogithub": "^14.0.0",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.21.4",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "bun run build && bun run --cwd Tests test",
    "test:build": "bun run build && bun run --cwd Tests build.js",
    "test:stress": "bun run build && bun run --cwd Tests stress.ts",
    "bump": "bumpp -r",
    "release": "rm bun.lock && bun install && turbo run build && turbo run publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "./Packages/adapter",
    "./Packages/types",
    "./Packages/server",
    "./Packages/client",
    "./Packages/swagger",
    "./Packages/validations",
    "./Packages/database",
    "./Tests"
  ]
}
