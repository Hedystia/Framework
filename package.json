{
  "name": "framework",
  "license": "MIT",
  "homepage": "https://docs.hedystia.com",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.6",
    "bumpp": "^10.4.1",
    "changelogithub": "^14.0.0",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.21.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "bun run build && bun run --cwd Tests test",
    "test:build": "bun run build && bun run --cwd Tests build.js",
    "test:stress": "bun run build && bun run --cwd Tests stress.ts",
    "bump": "bumpp && bun install && changelogithub",
    "release": "turbo run build && turbo run publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedystia/Hedystia"
  },
  "author": {
    "name": "Zastinian",
    "email": "contact@zastinian.com",
    "url": "https://github.com/Zastinian"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "./Packages/adapter",
    "./Packages/types",
    "./Packages/server",
    "./Packages/client",
    "./Packages/swagger",
    "./Packages/validations",
    "./Tests"
  ]
}
